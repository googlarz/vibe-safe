#!/bin/sh
# vibe-safe pre-commit hook
# Mechanical safety checks on every commit — no Claude required.
# Install: cp ~/.claude/skills/vibe-safe/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

CRED_PATTERN="sk-|pk_|ghp_|AKIA|api_key[[:space:]]*=|secret[[:space:]]*=|password[[:space:]]*=|Bearer |token[[:space:]]*="

bail() {
  echo ""
  echo "vibe-safe: $1"
  echo "$2"
  echo ""
  echo "$3"
  echo ""
  exit 1
}

# 1. Branch check
BRANCH=$(git branch --show-current 2>/dev/null)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  bail "STOP -- committing directly to $BRANCH." "" \
    "Create a branch: git checkout -b feature/your-change-name"
fi

# 2. Credential scan across ALL tracked files (not just staged)
CREDS=$(git grep -nE "$CRED_PATTERN" 2>/dev/null)
if [ -n "$CREDS" ]; then
  bail "STOP -- credential pattern found in tracked files:" "$CREDS" \
    "Credentials in git history are permanent even after deletion. Run: vibe-safe commit"
fi

# Capture staged diff once for all diff-based checks
STAGED_DIFF=$(git diff --cached 2>/dev/null)
ADDED=$(echo "$STAGED_DIFF" | grep "^+" | grep -v "^+++" 2>/dev/null)
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)

# 3. Danger zone check on staged files
DANGER=""
for f in $STAGED_FILES; do
  case "$f" in
    .env|.env.local|.env.production|.env.staging|.env.development|*.conf|Dockerfile|docker-compose*|\
    .github/workflows/*|Jenkinsfile|.circleci/*|.gitlab-ci.yml|\
    */migrations/*|*/schema/*|*.sql|\
    webpack.config.*|vite.config.*|tsconfig.json|\
    jest.config.*|vitest.config.*|codecov.yml|.nycrc|sonar-project.properties|\
    pytest.ini|setup.cfg|pyproject.toml|.coveragerc|\
    package.json|Gemfile|requirements.txt)
      DANGER="${DANGER:+$DANGER
}  $f (infrastructure/config/quality-gate)"
      ;;
  esac

  BASENAME=$(basename "$f" | tr '[:upper:]' '[:lower:]')
  case "$BASENAME" in
    *auth*|*login*|*session*|*jwt*|*oauth*|*permission*|*role*)
      DANGER="${DANGER:+$DANGER
}  $f (auth/security)"
      ;;
    .eslintrc*|.stylelintrc*)
      DANGER="${DANGER:+$DANGER
}  $f (quality-gate)"
      ;;
  esac

  # .vibesafe custom danger zones
  if [ -f ".vibesafe" ]; then
    while IFS= read -r line; do
      case "$line" in
        danger_zone:*)
          ZONE=$(echo "$line" | sed 's/^danger_zone:[[:space:]]*//')
          case "$f" in
            ${ZONE}*) DANGER="${DANGER:+$DANGER
}  $f (custom zone: $ZONE)" ;;
          esac
          ;;
      esac
    done < .vibesafe
  fi
done

if [ -n "$DANGER" ]; then
  bail "PAUSE -- Danger Zone files staged:" "$DANGER" \
    "These need developer review. Run: vibe-safe commit"
fi

# 4. Error suppression check
SUPPRESS=$(echo "$ADDED" | grep -E "@ts-ignore|@ts-nocheck|@ts-expect-error|eslint-disable" 2>/dev/null)
if [ -n "$SUPPRESS" ]; then
  bail "PAUSE -- Error suppression added:" "$SUPPRESS" \
    "Claude may have hidden errors instead of fixing them. Run: vibe-safe commit"
fi

# 5. Test bypass check
SKIPPED=$(echo "$ADDED" | grep -E "\.skip\(|[^a-z]xit\(|[^a-z]xdescribe\(|[^a-z]xtest\(" 2>/dev/null)
if [ -n "$SKIPPED" ]; then
  bail "PAUSE -- Tests bypassed:" "$SKIPPED" \
    "Claude may have skipped failing tests instead of fixing them. Run: vibe-safe commit"
fi

# 6. Debug artifact check (excluding test files)
DEBUG_FILES=$(echo "$STAGED_FILES" | grep -v -E "\.(test|spec)\." 2>/dev/null)
if [ -n "$DEBUG_FILES" ]; then
  DEBUG=$(echo "$ADDED" | grep -E "console\.(log|error|warn|debug)|debugger;" 2>/dev/null)
  if [ -n "$DEBUG" ]; then
    bail "PAUSE -- Debug output in non-test files:" "$DEBUG" \
      "Remove before committing or run: vibe-safe commit"
  fi
fi

# 7. Empty catch check
EMPTY_CATCH=$(echo "$ADDED" | grep -E "catch\s*\(\w*\)\s*\{[[:space:]]*\}|catch\s*\{[[:space:]]*\}" 2>/dev/null)
if [ -n "$EMPTY_CATCH" ]; then
  bail "PAUSE -- Empty catch block added:" "$EMPTY_CATCH" \
    "Errors silently swallowed. Run: vibe-safe commit"
fi

# 8. Lock file drift check
LOCK_CHANGED=$(echo "$STAGED_FILES" | grep -E "package-lock\.json|yarn\.lock|pnpm-lock\.yaml" 2>/dev/null)
PKG_CHANGED=$(echo "$STAGED_FILES" | grep "^package\.json$" 2>/dev/null)
if [ -n "$LOCK_CHANGED" ] && [ -z "$PKG_CHANGED" ]; then
  bail "PAUSE -- Lock file changed without package.json:" "$LOCK_CHANGED" \
    "Manual lock file edits are almost always wrong. Run: vibe-safe commit"
fi

# 9. Binary file check
BINARY=$(git diff --cached --numstat 2>/dev/null | awk '$1 == "-" && $2 == "-" {print "  " $3 " (binary)"}')
if [ -n "$BINARY" ]; then
  bail "PAUSE -- Binary files staged:" "$BINARY" \
    "Binary files bloat git history permanently. Run: vibe-safe commit"
fi

# 10. XSS sink check
XSS=$(echo "$ADDED" | grep -E "dangerouslySetInnerHTML|innerHTML\s*=|document\.write\(" 2>/dev/null)
if [ -n "$XSS" ]; then
  bail "PAUSE -- XSS sink added:" "$XSS" \
    "Any user input reaching this is a vulnerability. Run: vibe-safe commit"
fi

# 11. Code injection check
EVAL=$(echo "$ADDED" | grep -E "\beval\(" 2>/dev/null)
if [ -n "$EVAL" ]; then
  bail "PAUSE -- eval() added:" "$EVAL" \
    "Arbitrary code execution risk. Run: vibe-safe commit"
fi

# 12. SSL bypass check
SSL=$(echo "$ADDED" | grep -E "verify=False|NODE_TLS_REJECT_UNAUTHORIZED|rejectUnauthorized:\s*false|ssl_verify:\s*false" 2>/dev/null)
if [ -n "$SSL" ]; then
  bail "STOP -- SSL verification disabled:" "$SSL" \
    "Claude may have silenced a cert error by removing all TLS protection. Run: vibe-safe commit"
fi

# 13. CORS wildcard check
CORS=$(echo "$ADDED" | grep -E "origin:\s*['\"]?\*['\"]?|Access-Control-Allow-Origin:\s*\*" 2>/dev/null)
if [ -n "$CORS" ]; then
  bail "PAUSE -- CORS wildcard added:" "$CORS" \
    "API now accepts requests from any domain. Run: vibe-safe commit"
fi

# 14. .gitignore regression check
if echo "$STAGED_FILES" | grep -q "^\.gitignore$"; then
  REMOVED=$(echo "$STAGED_DIFF" | grep "^\-.gitignore" | grep -v "^---" 2>/dev/null)
  if [ -n "$REMOVED" ]; then
    bail "PAUSE -- .gitignore entries removed:" "$REMOVED" \
      "Previously ignored files are now tracked and may be committed. Run: vibe-safe commit"
  fi
fi

# 15. Timing hack check
TIMING=$(echo "$ADDED" | grep -E "setTimeout\s*\([^,]+,\s*[0-9]+|sleep\s*\([0-9]|time\.sleep\s*\([0-9]|asyncio\.sleep\s*\([0-9]" 2>/dev/null)
if [ -n "$TIMING" ]; then
  bail "PAUSE -- Hardcoded timing delay added:" "$TIMING" \
    "Claude may have papered over a race condition. Run: vibe-safe commit"
fi

# 16. Debug mode check (non-test files only)
NON_TEST_FILES=$(echo "$STAGED_FILES" | grep -v -E "\.(test|spec)\.|__tests__" 2>/dev/null)
if [ -n "$NON_TEST_FILES" ]; then
  DEBUG_MODE=$(echo "$ADDED" | grep -E "DEBUG\s*=\s*True|debug:\s*true|APP_ENV\s*=\s*['\"]?development" 2>/dev/null)
  if [ -n "$DEBUG_MODE" ]; then
    bail "PAUSE -- Debug mode in non-test file:" "$DEBUG_MODE" \
      "Check this isn't heading to production. Run: vibe-safe commit"
  fi
fi

# 17. TODO/FIXME stub check (implementation files only, not .md or test files)
IMPL_FILES=$(echo "$STAGED_FILES" | grep -v -E "\.(md|txt)$|\.(test|spec)\.|__tests__" 2>/dev/null)
if [ -n "$IMPL_FILES" ]; then
  TODO_STUB=$(echo "$ADDED" | grep -iE "(throw|raise).*(todo|not.?implemented|NotImplementedError)|//\s*TODO[^:]*:|#\s*FIXME[^:]*:" 2>/dev/null)
  if [ -n "$TODO_STUB" ]; then
    bail "PAUSE -- TODO/FIXME stub in implementation code:" "$TODO_STUB" \
      "Claude left a placeholder instead of implementing. This will fail at runtime."
  fi
fi

# 18. Commented-out code check
COMMENTED=$(echo "$ADDED" | grep -E "^\+\s*(//|#)\s*(const |let |var |function |return |import |export |if |for |while |class |def |async )" 2>/dev/null)
if [ -n "$COMMENTED" ]; then
  bail "PAUSE -- Commented-out code added:" "$COMMENTED" \
    "Claude may have been unsure — disabled code should not ship. Run: vibe-safe commit"
fi

# 19. Private key file check
KEY_EXT=$(echo "$STAGED_FILES" | grep -iE "\.(pem|key|pfx|p12|jks|crt|cer)$|^(id_rsa|id_ed25519|id_dsa|id_ecdsa)$" 2>/dev/null)
if [ -n "$KEY_EXT" ]; then
  bail "STOP -- Private key or certificate file staged:" "$KEY_EXT" \
    "Binary credentials are not caught by text grep. Keys in git history are permanently compromised."
fi

# 20. Destructive rm -rf in scripts
SCRIPT_FILES=$(echo "$STAGED_FILES" | grep -E "\.(sh|bash|zsh|fish|mk|Makefile)$|Makefile|\.github/workflows/" 2>/dev/null)
if [ -n "$SCRIPT_FILES" ]; then
  RMRF=$(echo "$ADDED" | grep -E "rm\s+-rf?\s+" 2>/dev/null)
  if [ -n "$RMRF" ]; then
    bail "PAUSE -- rm -rf in committed script:" "$RMRF" \
      "Verify this path is never a production directory before committing."
  fi
fi

# 21. String throw (no Error object) in JS/TS
JS_FILES=$(echo "$STAGED_FILES" | grep -E "\.(js|ts|jsx|tsx|mjs|cjs)$" 2>/dev/null)
if [ -n "$JS_FILES" ]; then
  STRING_THROW=$(echo "$ADDED" | grep -E "throw\s+['\"]" 2>/dev/null)
  if [ -n "$STRING_THROW" ]; then
    bail "PAUSE -- String thrown instead of Error object:" "$STRING_THROW" \
      "Stack trace is lost. Production bugs become undiagnosable. Use: throw new Error(\"message\")"
  fi
fi

# 22. .env.example drift
ENV_REFS=$(echo "$ADDED" | grep -E "process\.env\.|os\.environ\[|getenv\(|import\.meta\.env\." 2>/dev/null)
if [ -n "$ENV_REFS" ]; then
  ENV_EXAMPLE_CHANGED=$(echo "$STAGED_FILES" | grep -E "^\.env\.example$|^\.env\.sample$" 2>/dev/null)
  if [ -z "$ENV_EXAMPLE_CHANGED" ]; then
    bail "PAUSE -- New env variable referenced without .env.example update:" "$ENV_REFS" \
      "Other developers won't know to set this variable. Add it to .env.example first."
  fi
fi

# 23. Migration rollback check
MIGRATION_FILES=$(echo "$STAGED_FILES" | grep -E "migrations/|db/migrate/|_migration\." 2>/dev/null)
REQ_ROLLBACK=$([ -f ".vibesafe" ] && grep "^require_migration_rollback:[[:space:]]*true" .vibesafe 2>/dev/null || true)
if [ -n "$MIGRATION_FILES" ]; then
  for mf in $MIGRATION_FILES; do
    # Skip Django auto-reversible migrations
    if grep -q "from django.db import migrations" "$mf" 2>/dev/null; then
      continue
    fi
    if ! grep -qiE "def down|def downgrade|exports\.down|\.down\(|rollback\(|-- Down" "$mf" 2>/dev/null; then
      if [ -n "$REQ_ROLLBACK" ]; then
        bail "STOP -- Developer contract: migration without rollback: $mf" "" \
          "Your team requires all migrations to include a down/downgrade/rollback. Add one before committing."
      else
        bail "PAUSE -- Migration without rollback: $mf" "" \
          "This schema change cannot be undone automatically. Add a down() or rollback function. Run: vibe-safe commit"
      fi
    fi
  done
fi

# 24. Developer contracts from .vibesafe
if [ -f ".vibesafe" ]; then
  # max_changed_files (soft ceiling — warns and routes to SCOPE, does not hard block)
  MAX=$(grep "^max_changed_files:" .vibesafe 2>/dev/null | sed 's/.*:[[:space:]]*//' | head -1)
  if [ -n "$MAX" ]; then
    FILE_COUNT=0
    if [ -n "$STAGED_FILES" ]; then
      FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')
    fi
    if [ "$FILE_COUNT" -gt "$MAX" ]; then
      echo ""
      echo "vibe-safe: SCOPE WARNING -- $FILE_COUNT files staged, developer contract max is $MAX"
      echo "  Run: vibe-safe scope"
      echo "  Unexpected files may have been changed by Claude. Review before committing."
      echo ""
    fi
  fi
  # block_pattern — check per implementation file (skips test/md files)
  while IFS= read -r line; do
    case "$line" in
      block_pattern:*)
        PAT=$(echo "$line" | sed 's/^block_pattern:[[:space:]]*//')
        BLOCKED=""
        for sf in $STAGED_FILES; do
          case "$sf" in
            *.test.*|*.spec.*|*__tests__*|*_test.*|*.md|*.txt) continue ;;
          esac
          FILE_ADDED=$(git diff --cached -- "$sf" 2>/dev/null | grep "^+" | grep -v "^+++" 2>/dev/null)
          MATCH=$(echo "$FILE_ADDED" | grep -F "$PAT" 2>/dev/null)
          if [ -n "$MATCH" ]; then
            BLOCKED="${BLOCKED:+$BLOCKED
}$sf: $MATCH"
          fi
        done
        if [ -n "$BLOCKED" ]; then
          bail "STOP -- Developer contract: blocked pattern '$PAT' found in added code" "$BLOCKED" \
            "Your team has blocked this pattern. Remove it before committing."
        fi
        ;;
    esac
  done < .vibesafe
  # require_tests (enforced only when source files are staged)
  REQ_TESTS=$(grep "^require_tests:[[:space:]]*true" .vibesafe 2>/dev/null)
  if [ -n "$REQ_TESTS" ]; then
    SRC_FILES=$(echo "$STAGED_FILES" | grep -E "\.(js|ts|jsx|tsx|py|rb|go|rs|java|cs)$" | grep -v -E "\.(test|spec)\.|_test\." 2>/dev/null)
    TEST_FILES=$(echo "$STAGED_FILES" | grep -E "\.(test|spec)\.|_test\.|/tests/|/__tests__/" 2>/dev/null)
    if [ -n "$SRC_FILES" ] && [ -z "$TEST_FILES" ]; then
      bail "STOP -- Developer contract: require_tests=true, no test files staged" "$SRC_FILES" \
        "Your team requires test changes alongside source changes. Add or update tests. Run: vibe-safe commit"
    fi
  fi
fi

# 25. Missing await on async calls (common Claude bug)
JS_CHANGES=$(echo "$STAGED_FILES" | grep -E "\.(js|ts|jsx|tsx|mjs|cjs)$" 2>/dev/null)
if [ -n "$JS_CHANGES" ]; then
  MISSING_AWAIT=""
  for sf in $STAGED_FILES; do
    case "$sf" in *.js|*.ts|*.jsx|*.tsx|*.mjs|*.cjs) ;;
      *) continue ;;
    esac
    FILE_ADDED=$(git diff --cached -- "$sf" 2>/dev/null | grep "^+" | grep -v "^+++")
    MATCH=$(echo "$FILE_ADDED" | grep -E "=[[:space:]]*(fetch|axios\.(get|post|put|delete|patch)|prisma\.[a-zA-Z]+\.(find|create|update|delete|upsert|count|findFirst|findMany|aggregate)|db\.(query|execute|run|all|get))\(" 2>/dev/null | grep -v "await")
    [ -n "$MATCH" ] && MISSING_AWAIT="${MISSING_AWAIT:+$MISSING_AWAIT
}$sf: $MATCH"
  done
  [ -n "$MISSING_AWAIT" ] && echo "vibe-safe: possible missing await on async call — result may be a Promise, not a value
$MISSING_AWAIT"
fi

# 26. Math.random() in security-sensitive file
SEC_RAND=$(git diff --cached -- '*.js' '*.ts' '*.jsx' '*.tsx' 2>/dev/null | grep "^+" | grep -v "^+++" | grep -E "Math\.random\(\)" 2>/dev/null)
if [ -n "$SEC_RAND" ]; then
  SEC_FILES=$(echo "$STAGED_FILES" | grep -iE "auth|token|session|crypto|key|secret|password" 2>/dev/null)
  if [ -n "$SEC_FILES" ]; then
    bail "STOP — Math.random() in security-related file: use crypto.randomBytes() or crypto.randomUUID()
$SEC_RAND" "" ""
  fi
fi

# 27. SQL string concatenation (injection risk)
SQLI=$(git diff --cached 2>/dev/null | grep "^+" | grep -v "^+++" | grep -v -E "^(\+[[:space:]]*)?(#|//|\*)" | grep -E "['\"]([[:space:]]*(SELECT|INSERT|UPDATE|DELETE|WHERE))[^'\"]*['\"][[:space:]]*\+|f['\x27](SELECT|INSERT|UPDATE|DELETE).*\{" 2>/dev/null)
[ -n "$SQLI" ] && bail "STOP — SQL string concatenation: use parameterized queries, string-built SQL is injectable
$SQLI" "" ""

# 28. Shell injection risk
SHELL_INJ=$(git diff --cached 2>/dev/null | grep "^+" | grep -v "^+++" | grep -E "shell:[[:space:]]*true|shell=True|subprocess.*shell=True" 2>/dev/null)
[ -n "$SHELL_INJ" ] && bail "STOP — shell:true passes command through /bin/sh — unsanitized input becomes code execution
$SHELL_INJ" "" ""

# 29. Test file with no assertions
TEST_STAGED=$(echo "$STAGED_FILES" | grep -E "\.(test|spec)\.(js|ts|jsx|tsx)$|_test\.(js|ts|py|go|rb)$" 2>/dev/null)
if [ -n "$TEST_STAGED" ]; then
  for tf in $TEST_STAGED; do
    FILE_ADDED=$(git diff --cached -- "$tf" 2>/dev/null | grep "^+" | grep -v "^+++")
    HAS_TEST=$(echo "$FILE_ADDED" | grep -E "it\(|test\(|describe\(" 2>/dev/null)
    HAS_ASSERT=$(echo "$FILE_ADDED" | grep -E "expect\(|assert\.|\.toBe|\.toEqual|\.toHaveBeenCalled|\.toThrow|\.toMatch" 2>/dev/null)
    [ -n "$HAS_TEST" ] && [ -z "$HAS_ASSERT" ] && echo "vibe-safe: test added without assertions in $tf — test always passes regardless of behavior"
  done
fi

# 30. Coverage threshold drop (--cov-fail-under lowered)
COV_DROP=$(echo "$STAGED_DIFF" | grep "^-" | grep -v "^---" | grep -E "\-\-cov-fail-under[= ][0-9]|cov_fail_under[[:space:]]*=[[:space:]]*[0-9]|fail_under[[:space:]]*=[[:space:]]*[0-9]" 2>/dev/null)
[ -n "$COV_DROP" ] && echo "vibe-safe: coverage threshold lowered -- verify this wasn't done to make CI pass
$COV_DROP"

# 31. API key committed in client-side / frontend file (visible in browser)
FRONTEND_CRED=""
for f in $STAGED_FILES; do
  case "$f" in
    src/*|frontend/*|public/*|static/*|client/*|components/*|pages/*|app/*)
      FILE_ADDED=$(git diff --cached -- "$f" 2>/dev/null | grep "^+" | grep -v "^+++")
      MATCH=$(echo "$FILE_ADDED" | grep -E "sk-[a-zA-Z0-9]{20,}|pk_live_|pk_test_|AKIA[A-Z0-9]{16}|api[_-]?key[[:space:]]*[:=][[:space:]]*['\"][a-zA-Z0-9_\-]{16,}" 2>/dev/null)
      [ -n "$MATCH" ] && FRONTEND_CRED="${FRONTEND_CRED:+$FRONTEND_CRED
}$f: $MATCH"
      ;;
  esac
done
[ -n "$FRONTEND_CRED" ] && bail "STOP -- credential in client-side file: visible to anyone who opens DevTools" "$FRONTEND_CRED" \
  "Move to a server-side environment variable or route the call through a backend proxy."

# 32. Sensitive data in log statements
SECRET_LOG=$(echo "$ADDED" | grep -E "console\.(log|error|warn|info)\(|logger\.(info|debug|error|warn)\(|print\(|logging\.(info|debug|error|warning)\(" 2>/dev/null | grep -iE "password|secret|token|api.?key|private.?key|credential|auth" 2>/dev/null)
[ -n "$SECRET_LOG" ] && echo "vibe-safe: possible sensitive data in log output -- scrub before production
$SECRET_LOG"

# 33. Security header regression
HELMET_REMOVED=$(echo "$STAGED_DIFF" | grep "^-" | grep -v "^---" | grep -E "helmet\(\)|require.*['\"]helmet['\"]|import.*['\"]helmet['\"]" 2>/dev/null)
[ -n "$HELMET_REMOVED" ] && echo "vibe-safe: helmet removed -- verify security headers are still set elsewhere
$HELMET_REMOVED"
INSECURE_HDR=$(echo "$ADDED" | grep -iE "content-security-policy.*unsafe-eval|content-security-policy.*unsafe-inline|x-frame-options.*ALLOW-FROM|strict-transport-security.*max-age=0" 2>/dev/null)
[ -n "$INSECURE_HDR" ] && echo "vibe-safe: insecure security header configuration
$INSECURE_HDR"

# 34. New API route without rate limiting
for f in $STAGED_FILES; do
  case "$f" in *.js|*.ts|*.jsx|*.tsx|*.py|*.rb) ;;
    *) continue ;;
  esac
  FILE_ADDED=$(git diff --cached -- "$f" 2>/dev/null | grep "^+" | grep -v "^+++")
  NEW_ROUTES=$(echo "$FILE_ADDED" | grep -E "app\.(get|post|put|delete|patch)\(|router\.(get|post|put|delete|patch)\(|@app\.route\(|@router\.(get|post|put|delete)\(" 2>/dev/null)
  if [ -n "$NEW_ROUTES" ]; then
    HAS_RATE=$(grep -E "rateLimit|rate_limit|throttle|slowapi|limiter|RateLimit|express-rate-limit|django-ratelimit" "$f" 2>/dev/null)
    [ -z "$HAS_RATE" ] && echo "vibe-safe: new route in $f has no rate limiting -- add before exposing to traffic"
  fi
done

echo "vibe-safe: all 34 checks passed -- clear"
