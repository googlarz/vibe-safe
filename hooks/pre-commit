#!/bin/sh
# vibe-safe pre-commit hook
# Mechanical safety checks on every commit — no Claude required.
# Install: cp ~/.claude/skills/vibe-safe/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

CRED_PATTERN="sk-|pk_|ghp_|AKIA|api_key[[:space:]]*=|secret[[:space:]]*=|password[[:space:]]*=|Bearer |token[[:space:]]*="

bail() {
  echo ""
  echo "vibe-safe: $1"
  echo "$2"
  echo ""
  echo "$3"
  echo ""
  exit 1
}

# 1. Branch check
BRANCH=$(git branch --show-current 2>/dev/null)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  bail "STOP -- committing directly to $BRANCH." "" \
    "Create a branch: git checkout -b feature/your-change-name"
fi

# 2. Credential scan across ALL tracked files (not just staged)
CREDS=$(git grep -nE "$CRED_PATTERN" 2>/dev/null)
if [ -n "$CREDS" ]; then
  bail "STOP -- credential pattern found in tracked files:" "$CREDS" \
    "Credentials in git history are permanent even after deletion. Run: vibe-safe commit"
fi

# Capture staged diff once for all diff-based checks
STAGED_DIFF=$(git diff --cached 2>/dev/null)
ADDED=$(echo "$STAGED_DIFF" | grep "^+" | grep -v "^+++" 2>/dev/null)
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)

# 3. Danger zone check on staged files
DANGER=""
for f in $STAGED_FILES; do
  case "$f" in
    .env|.env.*|*.conf|Dockerfile|docker-compose*|\
    .github/workflows/*|Jenkinsfile|.circleci/*|.gitlab-ci.yml|\
    */migrations/*|*/schema/*|*.sql|\
    webpack.config.*|vite.config.*|tsconfig.json|\
    jest.config.*|vitest.config.*|codecov.yml|.nycrc|sonar-project.properties|\
    package.json|Gemfile|requirements.txt)
      DANGER="${DANGER:+$DANGER
}  $f (infrastructure/config/quality-gate)"
      ;;
  esac

  BASENAME=$(basename "$f" | tr '[:upper:]' '[:lower:]')
  case "$BASENAME" in
    *auth*|*login*|*session*|*jwt*|*oauth*|*permission*|*role*)
      DANGER="${DANGER:+$DANGER
}  $f (auth/security)"
      ;;
    .eslintrc*|.stylelintrc*)
      DANGER="${DANGER:+$DANGER
}  $f (quality-gate)"
      ;;
  esac

  # .vibesafe custom danger zones
  if [ -f ".vibesafe" ]; then
    while IFS= read -r line; do
      case "$line" in
        danger_zone:*)
          ZONE=$(echo "$line" | sed 's/^danger_zone:[[:space:]]*//')
          case "$f" in
            ${ZONE}*) DANGER="${DANGER:+$DANGER
}  $f (custom zone: $ZONE)" ;;
          esac
          ;;
      esac
    done < .vibesafe
  fi
done

if [ -n "$DANGER" ]; then
  bail "PAUSE -- Danger Zone files staged:" "$DANGER" \
    "These need developer review. Run: vibe-safe commit"
fi

# 4. Error suppression check
SUPPRESS=$(echo "$ADDED" | grep -E "@ts-ignore|@ts-nocheck|@ts-expect-error|eslint-disable" 2>/dev/null)
if [ -n "$SUPPRESS" ]; then
  bail "PAUSE -- Error suppression added:" "$SUPPRESS" \
    "Claude may have hidden errors instead of fixing them. Run: vibe-safe commit"
fi

# 5. Test bypass check
SKIPPED=$(echo "$ADDED" | grep -E "\.skip\(|[^a-z]xit\(|[^a-z]xdescribe\(|[^a-z]xtest\(" 2>/dev/null)
if [ -n "$SKIPPED" ]; then
  bail "PAUSE -- Tests bypassed:" "$SKIPPED" \
    "Claude may have skipped failing tests instead of fixing them. Run: vibe-safe commit"
fi

# 6. Debug artifact check (excluding test files)
DEBUG_FILES=$(echo "$STAGED_FILES" | grep -v -E "\.(test|spec)\." 2>/dev/null)
if [ -n "$DEBUG_FILES" ]; then
  DEBUG=$(echo "$ADDED" | grep -E "console\.(log|error|warn|debug)|debugger;" 2>/dev/null)
  if [ -n "$DEBUG" ]; then
    bail "PAUSE -- Debug output in non-test files:" "$DEBUG" \
      "Remove before committing or run: vibe-safe commit"
  fi
fi

# 7. Empty catch check
EMPTY_CATCH=$(echo "$ADDED" | grep -E "catch\s*\(\w*\)\s*\{[[:space:]]*\}|catch\s*\{[[:space:]]*\}" 2>/dev/null)
if [ -n "$EMPTY_CATCH" ]; then
  bail "PAUSE -- Empty catch block added:" "$EMPTY_CATCH" \
    "Errors silently swallowed. Run: vibe-safe commit"
fi

# 8. Lock file drift check
LOCK_CHANGED=$(echo "$STAGED_FILES" | grep -E "package-lock\.json|yarn\.lock|pnpm-lock\.yaml" 2>/dev/null)
PKG_CHANGED=$(echo "$STAGED_FILES" | grep "^package\.json$" 2>/dev/null)
if [ -n "$LOCK_CHANGED" ] && [ -z "$PKG_CHANGED" ]; then
  bail "PAUSE -- Lock file changed without package.json:" "$LOCK_CHANGED" \
    "Manual lock file edits are almost always wrong. Run: vibe-safe commit"
fi

# 9. Binary file check
BINARY=$(git diff --cached --numstat 2>/dev/null | awk '$1 == "-" && $2 == "-" {print "  " $3 " (binary)"}')
if [ -n "$BINARY" ]; then
  bail "PAUSE -- Binary files staged:" "$BINARY" \
    "Binary files bloat git history permanently. Run: vibe-safe commit"
fi

# 10. XSS sink check
XSS=$(echo "$ADDED" | grep -E "dangerouslySetInnerHTML|innerHTML\s*=|document\.write\(" 2>/dev/null)
if [ -n "$XSS" ]; then
  bail "PAUSE -- XSS sink added:" "$XSS" \
    "Any user input reaching this is a vulnerability. Run: vibe-safe commit"
fi

# 11. Code injection check
EVAL=$(echo "$ADDED" | grep -E "\beval\(" 2>/dev/null)
if [ -n "$EVAL" ]; then
  bail "PAUSE -- eval() added:" "$EVAL" \
    "Arbitrary code execution risk. Run: vibe-safe commit"
fi

# 12. SSL bypass check
SSL=$(echo "$ADDED" | grep -E "verify=False|NODE_TLS_REJECT_UNAUTHORIZED|rejectUnauthorized:\s*false|ssl_verify:\s*false" 2>/dev/null)
if [ -n "$SSL" ]; then
  bail "STOP -- SSL verification disabled:" "$SSL" \
    "Claude may have silenced a cert error by removing all TLS protection. Run: vibe-safe commit"
fi

# 13. CORS wildcard check
CORS=$(echo "$ADDED" | grep -E "origin:\s*['\"]?\*['\"]?|Access-Control-Allow-Origin:\s*\*" 2>/dev/null)
if [ -n "$CORS" ]; then
  bail "PAUSE -- CORS wildcard added:" "$CORS" \
    "API now accepts requests from any domain. Run: vibe-safe commit"
fi

# 14. .gitignore regression check
if echo "$STAGED_FILES" | grep -q "^\.gitignore$"; then
  REMOVED=$(echo "$STAGED_DIFF" | grep "^\-.gitignore" | grep -v "^---" 2>/dev/null)
  if [ -n "$REMOVED" ]; then
    bail "PAUSE -- .gitignore entries removed:" "$REMOVED" \
      "Previously ignored files are now tracked and may be committed. Run: vibe-safe commit"
  fi
fi

# 15. Timing hack check
TIMING=$(echo "$ADDED" | grep -E "setTimeout\s*\([^,]+,\s*[0-9]+|sleep\s*\([0-9]|time\.sleep\s*\([0-9]|asyncio\.sleep\s*\([0-9]" 2>/dev/null)
if [ -n "$TIMING" ]; then
  bail "PAUSE -- Hardcoded timing delay added:" "$TIMING" \
    "Claude may have papered over a race condition. Run: vibe-safe commit"
fi

# 16. Debug mode check (non-test files only)
NON_TEST_FILES=$(echo "$STAGED_FILES" | grep -v -E "\.(test|spec)\.|__tests__" 2>/dev/null)
if [ -n "$NON_TEST_FILES" ]; then
  DEBUG_MODE=$(echo "$ADDED" | grep -E "DEBUG\s*=\s*True|debug:\s*true|APP_ENV\s*=\s*['\"]?development" 2>/dev/null)
  if [ -n "$DEBUG_MODE" ]; then
    bail "PAUSE -- Debug mode in non-test file:" "$DEBUG_MODE" \
      "Check this isn't heading to production. Run: vibe-safe commit"
  fi
fi

echo "vibe-safe: all 16 checks passed -- clear"
